# Environment variables for council-platform.
#
# Rule: this file (and the platform itself) only declares INFRASTRUCTURE
# and OPERATIONAL config — never application state. Council references,
# admin keys, OpEx keys, and contract IDs are stored in the database via
# the council-console wallet flow, not via env vars. With multi-council a
# single platform instance can host many councils, each with its own keys.

# ENVIRONMENT
PORT=3020
MODE=development
LOG_LEVEL=TRACE

# DATABASE
DATABASE_URL=postgresql://admin:devpass@localhost:5433/council_platform_db

# STELLAR
NETWORK=testnet
NETWORK_FEE=1000000000

# SERVICE
SERVICE_DOMAIN=localhost
SERVICE_AUTH_SECRET= # 32 random bytes, base64 encoded. Used for JWT signing AND
                    # at-rest encryption of the per-council derivation root in
                    # council_metadata.encrypted_derivation_root.

# AUTH
CHALLENGE_TTL=900
SESSION_TTL=21600

# OPENTELEMETRY (opt-in)
# OTEL_DENO=true
# OTEL_SERVICE_NAME=council-platform
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# CORS — comma-separated list of allowed origins (optional, falls back to defaults)
# ALLOWED_ORIGINS=https://provider-testnet.moonlightprotocol.io,https://council-testnet.moonlightprotocol.io
