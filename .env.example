# ENVIRONMENT
PORT=3020
MODE=development
LOG_LEVEL=TRACE

# DATABASE
DATABASE_URL=postgresql://admin:devpass@localhost:5433/council_platform_db

# STELLAR
NETWORK=testnet
NETWORK_FEE=1000000000
CHANNEL_AUTH_ID=C...

# COUNCIL ADMIN KEY
COUNCIL_SK=S...

# OPEX (council's operating expense account)
OPEX_PUBLIC=G...
OPEX_SECRET=S...

# SERVICE
SERVICE_DOMAIN=localhost
SERVICE_AUTH_SECRET=

# AUTH
CHALLENGE_TTL=900
SESSION_TTL=21600

# OPENTELEMETRY (opt-in)
# OTEL_DENO=true
# OTEL_SERVICE_NAME=council-platform
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
