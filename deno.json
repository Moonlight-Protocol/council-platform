{
  "name": "@moonlight-protocol/council-platform",
  "version": "0.4.11",
  "license": "MIT",
  "exports": "./src/main.ts",
  "tasks": {
    "serve": "deno run --allow-all --unstable-kv src/main.ts",
    "test": "deno test --allow-all --unstable-kv",
    "test:unit": "deno test --allow-all --unstable-kv src/",
    "test:integration": "deno test --allow-all --unstable-kv --no-check --config tests/deno.json tests/",
    "db:generate": "deno -A --node-modules-dir npm:drizzle-kit generate",
    "db:migrate": "deno -A --node-modules-dir npm:drizzle-kit migrate",
    "db:push": "deno -A --node-modules-dir npm:drizzle-kit push",
    "db:studio": "deno -A --node-modules-dir npm:drizzle-kit studio",
    "generate": "deno task drizzle-kit generate",
    "migrate": "deno task drizzle-kit migrate",
    "drizzle-kit": "deno run --env -A --node-modules-dir npm:drizzle-kit"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@/": "./src/",
    "@colibri/core": "jsr:@colibri/core@^0.16.1",
    "@stellar/stellar-sdk": "npm:@stellar/stellar-sdk@14.6.1",
    "@stellar/stellar-sdk/contract": "npm:@stellar/stellar-sdk@14.6.1/contract",
    "@drizzle-team/brocli": "npm:@drizzle-team/brocli@^0.11.0",
    "@fifo/convee": "jsr:@fifo/convee@^0.10.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@zaubrik/djwt": "jsr:@zaubrik/djwt@^3.0.2",
    "drizzle-kit": "npm:drizzle-kit@^0.31.6",
    "drizzle-orm": "npm:drizzle-orm@^0.44.7",
    "postgres": "npm:postgres@^3.4.7",
    "tslib": "npm:tslib@2.5.0",
    "@noble/curves": "jsr:@noble/curves@^1.8.0",
    "@noble/curves/p256": "jsr:@noble/curves@^1.8.0/p256",
    "@noble/curves/abstract/modular": "jsr:@noble/curves@^1.8.0/abstract/modular",
    "@noble/hashes": "jsr:@noble/hashes@^1.6.1",
    "@noble/hashes/sha256": "jsr:@noble/hashes@^1.6.1/sha256",
    "@noble/hashes/hkdf": "jsr:@noble/hashes@^1.6.1/hkdf",
    "stellar-sdk": "npm:@stellar/stellar-sdk@14.6.1",
    "stellar-sdk/rpc": "npm:@stellar/stellar-sdk@14.6.1/rpc",
    "buffer": "npm:buffer@^6.0.3",
    "@oak/oak": "jsr:@oak/oak@^17.1.4",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "zod": "npm:zod@3.24.2",
    "chalk": "npm:chalk@^5.3.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0"
  }
}
